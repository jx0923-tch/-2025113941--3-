import numpy as np
import matplotlib.pyplot as plt
from datetime import datetime, timedelta

np.random.seed(42)

print("=" * 60)
print("任务2: 金融数据分析实战")
print("=" * 60)

def generate_stock_data(days=252, start_price=100, drift=0.05, volatility=0.2):
    returns = np.random.normal(drift/252, volatility/np.sqrt(252), days)
    prices = start_price * np.exp(np.cumsum(returns))
    return prices

dates = np.array([datetime(2023, 1, 1) + timedelta(days=i) for i in range(252)])
stock_prices = generate_stock_data(252, 100, 0.08, 0.25)
stock_prices2 = generate_stock_data(252, 95, 0.06, 0.30)
stock_prices3 = generate_stock_data(252, 110, 0.10, 0.20)

price_matrix = np.column_stack([stock_prices, stock_prices2, stock_prices3])
print(f"股票价格数据形状: {price_matrix.shape}")
print(f"前10天价格:\n{price_matrix[:10]}")

returns_matrix = np.diff(price_matrix, axis=0) / price_matrix[:-1, :]
print(f"\n日收益率形状: {returns_matrix.shape}")
print(f"前10天收益率:\n{returns_matrix[:10]}")

log_returns = np.diff(np.log(price_matrix), axis=0)
print(f"对数收益率形状: {log_returns.shape}")

mean_returns = np.mean(returns_matrix, axis=0) * 252
volatilities = np.std(returns_matrix, axis=0) * np.sqrt(252)
print(f"\n年化收益率: {mean_returns}")
print(f"年化波动率: {volatilities}")

sharpe_ratio = mean_returns / volatilities
print(f"夏普比率: {sharpe_ratio}")

covariance = np.cov(returns_matrix.T) * 252
correlation = np.corrcoef(returns_matrix.T)
print(f"\n协方差矩阵 (年化):\n{covariance}")
print(f"相关系数矩阵:\n{correlation}")

def moving_average(data, window):
    weights = np.ones(window) / window
    return np.convolve(data, weights, mode='valid')

ma_20_1 = moving_average(stock_prices, 20)
ma_50_1 = moving_average(stock_prices, 50)
ma_20_2 = moving_average(stock_prices2, 20)
ma_50_2 = moving_average(stock_prices2, 50)

print(f"\n移动平均线 (股票1):")
print(f"SMA 20 (前10个): {ma_20_1[:10]}")
print(f"SMA 50 (前10个): {ma_50_1[:10]}")

ema_20 = np.zeros(len(stock_prices))
alpha = 2 / (20 + 1)
ema_20[0] = stock_prices[0]
for i in range(1, len(stock_prices)):
    ema_20[i] = alpha * stock_prices[i] + (1 - alpha) * ema_20[i-1]
print(f"EMA 20 (前10个): {ema_20[:10]}")

weights = np.array([0.4, 0.3, 0.3])
portfolio_returns = np.dot(returns_matrix, weights)
portfolio_mean = np.mean(portfolio_returns) * 252
portfolio_std = np.std(portfolio_returns) * np.sqrt(252)
portfolio_sharpe = portfolio_mean / portfolio_std

print(f"\n投资组合分析 (权重 {weights}):")
print(f"组合年化收益率: {portfolio_mean:.4f}")
print(f"组合年化波动率: {portfolio_std:.4f}")
print(f"组合夏普比率: {portfolio_sharpe:.4f}")

num_portfolios = 10000
results = np.zeros((3, num_portfolios))
weights_record = []

for i in range(num_portfolios):
    w = np.random.random(3)
    w = w / np.sum(w)
    weights_record.append(w)
    
    port_return = np.dot(mean_returns, w)
    port_std = np.sqrt(np.dot(w.T, np.dot(covariance, w)))
    port_sharpe = port_return / port_std
    
    results[0, i] = port_return
    results[1, i] = port_std
    results[2, i] = port_sharpe

max_sharpe_idx = np.argmax(results[2])
optimal_weights = weights_record[max_sharpe_idx]
print(f"\n最优投资组合 (最大夏普比率):")
print(f"权重: {optimal_weights}")
print(f"年化收益率: {results[0, max_sharpe_idx]:.4f}")
print(f"年化波动率: {results[1, max_sharpe_idx]:.4f}")
print(f"夏普比率: {results[2, max_sharpe_idx]:.4f}")

min_vol_idx = np.argmin(results[1])
min_vol_weights = weights_record[min_vol_idx]
print(f"\n最小波动率投资组合:")
print(f"权重: {min_vol_weights}")
print(f"年化收益率: {results[0, min_vol_idx]:.4f}")
print(f"年化波动率: {results[1, min_vol_idx]:.4f}")

print(f"\n回撤分析:")
cumulative_returns = np.cumprod(1 + portfolio_returns)
running_max = np.maximum.accumulate(cumulative_returns)
drawdown = (cumulative_returns - running_max) / running_max
max_drawdown = np.min(drawdown)
print(f"最大回撤: {max_drawdown:.4f}")
print(f"最大回撤发生位置: {np.argmin(drawdown)}")

plt.figure(figsize=(15, 10))

plt.subplot(2, 3, 1)
plt.plot(dates, stock_prices, label='Stock 1', alpha=0.7)
plt.plot(dates, stock_prices2, label='Stock 2', alpha=0.7)
plt.plot(dates, stock_prices3, label='Stock 3', alpha=0.7)
plt.title('股票价格走势')
plt.xlabel('日期')
plt.ylabel('价格')
plt.legend()
plt.grid(True, alpha=0.3)

plt.subplot(2, 3, 2)
plt.plot(dates[1:], returns_matrix[:, 0], label='Stock 1', alpha=0.5)
plt.plot(dates[1:], returns_matrix[:, 1], label='Stock 2', alpha=0.5)
plt.plot(dates[1:], returns_matrix[:, 2], label='Stock 3', alpha=0.5)
plt.title('日收益率')
plt.xlabel('日期')
plt.ylabel('收益率')
plt.legend()
plt.grid(True, alpha=0.3)

plt.subplot(2, 3, 3)
plt.plot(dates[19:], ma_20_1, label='SMA 20', linewidth=2)
plt.plot(dates[49:], ma_50_1, label='SMA 50', linewidth=2)
plt.plot(dates, stock_prices, label='Price', alpha=0.5)
plt.title('移动平均线 (股票1)')
plt.xlabel('日期')
plt.ylabel('价格')
plt.legend()
plt.grid(True, alpha=0.3)

plt.subplot(2, 3, 4)
plt.scatter(results[1, :], results[0, :], c=results[2, :], marker='.', alpha=0.3, cmap='viridis')
plt.scatter(results[1, min_vol_idx], results[0, min_vol_idx], c='red', s=100, marker='*', label='最小波动率')
plt.scatter(results[1, max_sharpe_idx], results[0, max_sharpe_idx], c='gold', s=100, marker='*', label='最大夏普比率')
plt.colorbar(label='夏普比率')
plt.title('有效前沿')
plt.xlabel('波动率')
plt.ylabel('收益率')
plt.legend()
plt.grid(True, alpha=0.3)

plt.subplot(2, 3, 5)
plt.hist(portfolio_returns, bins=50, alpha=0.7, edgecolor='black')
plt.axvline(np.mean(portfolio_returns), color='red', linestyle='--', label='均值')
plt.axvline(np.mean(portfolio_returns) - portfolio_std, color='orange', linestyle='--', label='±1标准差')
plt.axvline(np.mean(portfolio_returns) + portfolio_std, color='orange', linestyle='--')
plt.title('投资组合收益率分布')
plt.xlabel('收益率')
plt.ylabel('频率')
plt.legend()
plt.grid(True, alpha=0.3)

plt.subplot(2, 3, 6)
plt.plot(dates[1:], cumulative_returns, label='累积收益', linewidth=2)
plt.fill_between(dates[1:], cumulative_returns, running_max, alpha=0.3, color='red', label='回撤区域')
plt.title('累积收益与回撤')
plt.xlabel('日期')
plt.ylabel('累积收益')
plt.legend()
plt.grid(True, alpha=0.3)

plt.tight_layout()
plt.show()

print("\n" + "=" * 60)
print("任务2完成!")
print("=" * 60)
