def matrix_operations(A, B):
    print(f"\n矩阵A:\n{A}")
    print(f"矩阵B:\n{B}")
    
    addition = A + B
    print(f"加法:\n{addition}")
    
    subtraction = A - B
    print(f"减法:\n{subtraction}")
    
    multiplication = np.matmul(A, B)
    print(f"矩阵乘法:\n{multiplication}")
    
    elementwise_mul = A * B
    print(f"元素乘法:\n{elementwise_mul}")
    
    transpose_A = A.T
    transpose_B = B.T
    print(f"A的转置:\n{transpose_A}")
    print(f"B的转置:\n{transpose_B}")
    
    det_A = np.linalg.det(A)
    det_B = np.linalg.det(B)
    print(f"A的行列式: {det_A:.4f}")
    print(f"B的行列式: {det_B:.4f}")
    
    try:
        inv_A = np.linalg.inv(A)
        inv_B = np.linalg.inv(B)
        print(f"A的逆矩阵:\n{inv_A}")
        print(f"B的逆矩阵:\n{inv_B}")
    except np.linalg.LinAlgError:
        print("矩阵不可逆")
    
    trace_A = np.trace(A)
    trace_B = np.trace(B)
    print(f"A的迹: {trace_A}")
    print(f"B的迹: {trace_B}")
    
    return addition, multiplication

mat1 = np.array([[1, 2], [3, 4]])
mat2 = np.array([[5, 6], [7, 8]])
matrix_operations(mat1, mat2)

