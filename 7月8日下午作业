prices = np.random.rand(100) * 100 + 50

def moving_average_conv(data, window):
    return np.convolve(data, np.ones(window)/window, mode='valid')

def moving_average_cumsum(data, window):
    cumsum = np.cumsum(np.insert(data, 0, 0))
    return (cumsum[window:] - cumsum[:-window]) / window

window5_conv = moving_average_conv(prices, 5)
window20_conv = moving_average_conv(prices, 20)
window5_cumsum = moving_average_cumsum(prices, 5)

print(f"卷积方法5日MA前5个值: {window5_conv[:5]}")
print(f"累积和方法5日MA前5个值: {window5_cumsum[:5]}")
print(f"两种方法结果相等: {np.allclose(window5_conv, window5_cumsum)}")

%timeit moving_average_conv(prices, 5)
%timeit moving_average_cumsum(prices, 5)

large_prices = np.random.rand(10000) * 100 + 50
%timeit moving_average_conv(large_prices, 20)
%timeit moving_average_cumsum(large_prices, 20)
