def monte_carlo_stock_prices(S0, mu, sigma, T, dt, n_simulations):
    n_steps = int(T / dt)
    returns = np.random.randn(n_simulations, n_steps) * sigma * np.sqrt(dt) + (mu - 0.5 * sigma**2) * dt
    paths = np.zeros((n_simulations, n_steps + 1))
    paths[:, 0] = S0
    np.cumsum(returns, axis=1, out=returns)
    paths[:, 1:] = S0 * np.exp(returns)
    return paths

S0, mu, sigma, T = 100, 0.1, 0.2, 1
dt = 1/252
sim_paths = monte_carlo_stock_prices(S0, mu, sigma, T, dt, 10000)
