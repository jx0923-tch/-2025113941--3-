import numpy as np

np.random.seed(42)
A = np.random.randint(1, 10, size=(2, 3))
B = np.random.randint(1, 10, size=(2, 3))

print("数组A (2x3):")
print(A)
print("\n数组B (2x3):")
print(B)

elementwise = A * B
print(f"\n逐元素乘法 (A * B):\n{elementwise}")

matrix_product = A @ B.T
print(f"矩阵乘法 (A @ B.T):\n{matrix_product}")

arr_sum = np.array([[1, 2], [3, 4]])
print(f"\n数组:\n{arr_sum}")

row_sum = np.sum(arr_sum, axis=1)
col_sum = np.sum(arr_sum, axis=0)
print(f"按行求和 (axis=1): {row_sum}")
print(f"按列求和 (axis=0): {col_sum}")

arr_stats = np.array([1.2, 3.5, 2.8])
print(f"\n数组: {arr_stats}")

mean_val = np.mean(arr_stats)
std_val = np.std(arr_stats)
rounded = np.round(arr_stats)

print(f"均值: {mean_val:.2f}")
print(f"标准差: {std_val:.2f}")
print(f"四舍五入: {rounded}")
